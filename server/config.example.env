VPN_ADMIN_API_KEY=dev-admin-key

VPN_STORAGE_BACKEND=memory
VPN_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/vpn_platform?sslmode=disable

VPN_ALIPAY_ENABLED=true
VPN_ALIPAY_SANDBOX=false
VPN_ALIPAY_APP_ID=2021000000000000
VPN_ALIPAY_NOTIFY_URL=https://your-domain.example.com/wallet/topups/alipay/callback
VPN_ALIPAY_SUBJECT_PREFIX=VPN Points Recharge

# 二选一：直接填 PEM 内容（把换行写成 \n），或填写文件路径
VPN_ALIPAY_PRIVATE_KEY=
VPN_ALIPAY_PUBLIC_KEY=

VPN_ALIPAY_PRIVATE_KEY_FILE=./certs/alipay-app-private-key.pem
VPN_ALIPAY_PUBLIC_KEY_FILE=./certs/alipay-platform-public-key.pem

# 可选，默认会根据 sandbox 自动切换
VPN_ALIPAY_GATEWAY_URL=
